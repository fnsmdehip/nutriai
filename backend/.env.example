# Server Configuration
PORT=3001
NODE_ENV=development

# Database Configuration (PostgreSQL)
POSTGRES_DB=nutridb
POSTGRES_USER=user
POSTGRES_PASSWORD=password
DATABASE_URL=postgresql://user:password@localhost:5432/nutridb # For local connection outside Docker

# Redis Configuration
REDIS_URL=redis://localhost:6379 # For local connection outside Docker

# Firebase Configuration
# Path to your Firebase Admin SDK service account key JSON file
# Download from Firebase Console > Project Settings > Service accounts > Generate new private key
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=

# Google AI Configuration
# Get from Google AI Studio or Google Cloud Console
GOOGLE_AI_API_KEY= 