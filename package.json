{
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "format": "prettier --write \"app/**/*.{js,jsx,ts,tsx}\"",
    "validate": "npm run lint && npm run typecheck",
    "prepare": "husky",
    "fix:types": "node fix-type-issues.js",
    "update:theme": "node update-theme-imports.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "postinstall": "node fix-expo-icons.js && npx react-native-asset"
  },
  "devDependencies": {
    "@babel/plugin-proposal-export-namespace-from": "^7.18.9",
    "@babel/plugin-transform-class-properties": "^7.25.9",
    "@babel/plugin-transform-private-methods": "^7.25.9",
    "@react-native-community/cli": "^13.6.9",
    "@react-native/metro-config": "^0.79.0",
    "@react-navigation/bottom-tabs": "^7.3.10",
    "@react-navigation/native": "^7.1.6",
    "@react-navigation/stack": "^7.2.10",
    "@types/react": "^18.3.12",
    "@types/react-native": "^0.72.8",
    "@types/react-native-vector-icons": "^6.4.18",
    "@types/react-navigation": "^3.0.8",
    "@types/react-redux": "^7.1.34",
    "@typescript-eslint/eslint-plugin": "^8.29.1",
    "@typescript-eslint/parser": "^8.29.1",
    "babel-plugin-transform-define": "^2.1.4",
    "eslint": "^9.24.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-native": "^5.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.2",
    "metro-react-native-babel-preset": "^0.77.0",
    "prettier": "^3.2.5",
    "react-native-asset": "^2.1.1",
    "react-native-svg-transformer": "^1.5.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@expo/metro-runtime": "~3.2.1",
    "@expo/vector-icons": "^14.0.2",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-community/datetimepicker": "8.0.1",
    "@react-native-picker/picker": "2.7.5",
    "@react-navigation/native-stack": "^7.3.10",
    "@reduxjs/toolkit": "^2.2.6",
    "@types/uuid": "^9.0.8",
    "expo": "~51.0.21",
    "expo-barcode-scanner": "~13.0.1",
    "expo-battery": "~8.0.1",
    "expo-camera": "~15.0.14",
    "expo-dev-client": "~4.0.20",
    "expo-haptics": "~13.0.1",
    "expo-image": "~1.12.12",
    "expo-image-manipulator": "~12.0.5",
    "expo-image-picker": "~15.0.7",
    "expo-linear-gradient": "~13.0.2",
    "expo-notifications": "~0.28.10",
    "expo-updates": "~0.25.18",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-i18next": "^14.1.2",
    "react-native": "0.74.3",
    "react-native-camera": "^4.2.1",
    "react-native-chart-kit": "^6.12.0",
    "react-native-dotenv": "^3.4.11",
    "react-native-gesture-handler": "~2.16.1",
    "react-native-google-fit": "^0.21.0",
    "react-native-google-mobile-ads": "^14.11.0",
    "react-native-health": "^1.19.0",
    "react-native-purchases": "^8.12.0",
    "react-native-reanimated": "~3.10.1",
    "react-native-safe-area-context": "4.10.1",
    "react-native-svg": "15.2.0",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-vector-icons": "^10.2.0",
    "react-native-web": "~0.19.10",
    "react-redux": "^9.1.2",
    "uuid": "^9.0.1",
    "whatwg-url": "^13.0.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "name": "Nutri AI",
  "version": "1.0.0"
}
