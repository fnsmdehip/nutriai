{
  "expo": {
    "name": "Nutri AI",
    "slug": "nutri-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./app/assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./app/assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nutriai.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Nutri AI uses the camera to take pictures of food for nutrition analysis",
        "NSPhotoLibraryUsageDescription": "Nutri AI needs access to your photos to analyze food images",
        "UIRequiresFullScreen": true,
        "UIStatusBarHidden": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./app/assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.nutriai.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./app/assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "04c7bff1-f241-49d8-9c24-b4ee680c1579"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "enabled": true,
      "fallbackToCacheTimeout": 0
    },
    "plugins": [
      "expo-camera",
      "expo-image-picker",
      [
        "expo-updates",
        {
          "initialConfig": {
            "checkAutomatically": "ON_LOAD"
          }
        }
      ]
    ],
    "owner": "fnsmdehip"
  }
}
